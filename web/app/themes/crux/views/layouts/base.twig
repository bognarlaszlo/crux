{#
    @var navbar_theme string
#}

{% set navbar_theme = navbar_theme|default('light') %}

<!doctype html>
<html {{ site.language_attributes }}>
<head>
    <meta charset="{{ site.charset }}">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{ title|default('Crux') }}</title>

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {{ function('wp_head') }}
</head>
<body {{ function('body_class') }}>
    {% include 'components/navigation.twig' with { menu: primary_menu, navbar_theme } only %}

    {% block header %}{% endblock %}
    {% block content %}{% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}

    {% include 'components/footer.twig' %}
    {{ function('wp_footer') }}
</body>
</html>
