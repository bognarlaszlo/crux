<ul class="list-unstyled vstack gap-5">
    {% for item in list %}
        <li class="d-flex align-items-start gap-5">
            <div class="d-inline-flex p-3 rounded-circle text-primary bg-green-200">
                {% include 'components/svg.html.twig' with { name: item.icon } only %}
            </div>

            <div class="py-2">
                <h6 class="mb-3 text-primary ff-sans-serif fs-7 fw-600">
                    {{ item.title }}
                </h6>

                <p>{{ item.text }}</p>
            </div>
        </li>
    {% endfor %}
</ul>
