<div class="card mt-7 overflow-hidden">
    <div class="card-body p-5 p-md-7 bg-gradient-green text-primary">
        <div class="row align-items-center g-6">
            <div class="col-auto">
                <div class="p-3 border border-primary rounded-circle">
                    {% include 'components/svg.html.twig' with { name: 'nature', attributes: { width: 46, height: 46 } } only %}
                </div>
            </div>
            <div class="col-xl-5">
                <h3>{{ sustainability.title }}</h3>
            </div>
            <div class="col-xl">
                <p><strong>{{ sustainability.subtitle }}</strong></p>
                <p>{{ sustainability.text }}</p>
                <a href="{{ sustainability.action.url }}" class="mt-3 btn btn-primary">{{ sustainability.action.label }}</a>
            </div>
        </div>
    </div>
</div>
