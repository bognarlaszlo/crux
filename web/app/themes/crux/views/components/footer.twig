<footer class="pt-7 pb-5 bg-primary text-secondary text-center fs-10">
    <div class="container">
        {{ source('@images/svg/logo.svg') }}

        <div class="grid grid-cols-1 grid-cols-md-3 w-fit-content mt-10 mx-auto">
            {% for link in footer.links %}
                <a href="{{ link.url }}" class="link-secondary text-decoration-none">{{ link.label }}</a>
            {% endfor %}
        </div>

        <hr class="my-5 text-gray-400">

        <span>&copy; {{ 'now'|date('Y') }} {{ footer.copyright }}</span>
    </div>
</footer>
