{#
    @var menu Timber\Menu
    @var navbar_theme string
#}

<nav class="navbar navbar-expand-lg" data-bs-theme="{{ navbar_theme|default('light') }}">
    <div class="container">
        <a class="navbar-brand" href="/">
            {{ source('@images/logo.svg') }}
        </a>
        
        <ul class="navbar-nav">
            {% for item in menu.items %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ item.link }}">
                        {{ item.title }}
                    </a>
                </li>
            {% endfor %}
        </ul>
    </div>
</nav>
