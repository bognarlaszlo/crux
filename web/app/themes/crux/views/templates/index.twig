{% extends "layouts/base.twig" %}

{% set navbar_theme = 'dark' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('home') }}
{% endblock %}

{% block header %}
    {% embed 'components/site-header.twig' with { class: ['py-xxl', 'bg-velvet'] } %}
        {% block content %}
            <div class="row align-items-center justify-content-between h-100">
                <div class="col-lg-6 prose text-secondary" style="--prose-flow: 2em;">
                    <h1>
                        <strong>Fenntartható</strong> növekedés. Felelős befektetés.
                    </h1>
                    <p><strong>A Crux Tőkealap-kezelő Zrt. magán,- és kockázati tőkealapok kezelésével foglalkozik.</strong></p>
                    <p>Tevékenységünk célja, hogy közép- és hosszú távú finanszírozást biztosítsunk nagy növekedési potenciállal rendelkező vállalkozások számára, miközben befektetőink számára stabil, értékalapú portfóliót építünk. Az alapkezelő működését a szakmai megalapozottság, az átláthatóság és a felelős működés elvei határozzák meg.</p>
                    <div class="hstack gap-3 mt-7">
                        <a href="" class="btn btn-secondary">Kezelt alapok megtekintése</a>
                        <a href="" class="btn btn-outline-secondary">Rólunk</a>
                    </div>
                </div>
                <div class="col-lg-5">
                    {% include 'components/figure.twig' with {
                        pattern: 'end',
                        src: asset('images/home/hero.jpg'),
                        ratio: '453 / 575',
                        color: 'green-700'
                    } only %}
                </div>
            </div>
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block content %}
    <main class="container py-5">
        <h1>{{ site.name }}</h1>
    </main>
{% endblock %}
