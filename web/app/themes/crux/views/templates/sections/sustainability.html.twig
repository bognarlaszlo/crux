<section {{ html_attr({ class }) }}>
    <div class="container">
        <div class="row gy-8">
            {% if detailed %}
                <div class="row gy-5 align-items-center justify-content-between">
                    <div class="col-lg-5">
                        {% include 'components/figure.twig' with {
                            pattern: 'start',
                            src: asset('images/architecture/exterior-03.png'),
                            ratio: '453 / 575',
                            color: 'gray-300'
                        } only %}
                    </div>
                    <div class="col-lg-6">
                        {% include 'components/section-title.html.twig' with { title: sustainability.title, classes: 'mb-6' } only %}
                        {% include 'components/icon-list.html.twig' with { list: sustainability.items } %}
                    </div>
                </div>
            {% endif %}

            <div class="col-12">
                <div class="card overflow-hidden">
                    <div class="card-body p-5 p-md-7 bg-gradient-green text-primary">
                        <div class="row align-items-center g-6">
                            <div class="col-auto">
                                <div class="p-3 border border-primary rounded-circle">
                                    {% include 'components/svg.html.twig' with { name: 'nature', attributes: { width: 46, height: 46 } } only %}
                                </div>
                            </div>
                            <div class="col-xl-5">
                                <h3>{{ sustainability.card.title }}</h3>
                            </div>
                            <div class="col-xl">
                                <p><strong>{{ sustainability.card.subtitle }}</strong></p>
                                <p>{{ sustainability.card.text }}</p>
                                <a href="{{ sustainability.card.action.url }}" class="mt-3 btn btn-primary">{{ sustainability.card.action.label }}</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
