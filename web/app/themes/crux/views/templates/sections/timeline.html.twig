<section>
    <div class="container">
        <div class="card p-5 p-md-7 bg-gradient">
            <div class="row gy-3 gx-8">
                <div class="col-lg-auto">
                    {% include 'components/section-title.html.twig' with { title: timeline.title } %}
                </div>
                <div class="col-lg">
                    <ul class="list-timeline mb-0">
                        {% for item in timeline.items %}
                            <li>{{ item }}</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
