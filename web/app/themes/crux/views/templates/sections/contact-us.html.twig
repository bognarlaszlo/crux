<section class="py-7 bg-gradient">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg">
                <h3>
                    {{ contact.title }}<br>
                    <strong class="fw-500">{{ contact.subtitle }}</strong>
                </h3>
            </div>
            <div class="col-lg-auto text-lg-end">
                <p><a href="{{ contact.email.url }}" class="link-body-emphasis text-decoration-none">{{ contact.email.label }}</a></p>
                <p><a href="{{ contact.phone.url }}" class="link-body-emphasis text-decoration-none">{{ contact.phone.label }}</a></p>
            </div>
            <div class="col-lg-auto">
                <a href="{{ contact.action.url }}" class="btn btn-primary">{{ contact.action.label }}</a>
            </div>
        </div>
    </div>
</section>
